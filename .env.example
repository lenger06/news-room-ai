NEWSROOM_NAME="Defy Logic News"

OPENAI_API_KEY="sk-..."
TAVILY_API_KEY="tvly-..."
PEXELS_API_KEY=""          # Free at pexels.com/api — used for video b-roll search

# HeyGen — AI anchor video generation (https://app.heygen.com/settings?nav=API)
HEYGEN_API_KEY="..."
HEYGEN_AVATAR_ID=""   # From: GET https://api.heygen.com/v2/avatars
HEYGEN_VOICE_ID=""    # From: GET https://api.heygen.com/v2/voices

# YouTube — publisher agent
# Download OAuth2 credentials from Google Cloud Console → APIs & Services → Credentials
YOUTUBE_CLIENT_SECRETS_PATH=credentials/youtube_client_secrets.json

HOST=0.0.0.0
PORT=8091
DEBUG=True
LOG_LEVEL=INFO

ARTICLES_DIR=./output/articles
SCRIPTS_DIR=./output/scripts
MEDIA_DIR=./output/media
